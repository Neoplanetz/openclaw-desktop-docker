# ============================================================
# OpenClaw Desktop — User Configuration
# ============================================================
# Edit these values and run:  docker compose up -d --build
#
# NOTE: If you change CLAW_USER after the first run,
#       delete the old volume first:
#       docker compose down -v && docker compose up -d --build
# ============================================================

CLAW_USER=claw
CLAW_PASSWORD=claw1234
OPENCLAW_VERSION=latest

# OpenClaw browser (CDP Chrome) — set to true to enable
OPENCLAW_BROWSER_ENABLED=false
